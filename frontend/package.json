{
  "name": "neustudy-admin-frontend",
  "version": "0.2.0",
  "private": true,
  "description": "A dashboard on Vue.js 3.x & TypeScript created by Vite.",
  "keywords": [
    "dashboard",
    "vue",
    "vuejs",
    "vue3",
    "typescript",
    "vite"
  ],
  "repository": "https://github.com/XyeHyin/neustudy-admin.git",
  "license": "MIT",
  "author": "XyeHyin",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build --force",
    "lint": "eslint \"src/**/*.{vue,js,jsx,cjs,mjs,ts,tsx,cts,mts}\" --fix",
    "format": "prettier --write src/"
  },
  "type": "module",
  "dependencies": {
    "@vicons/fa": "^0.13.0",
    "@vicons/ionicons5": "^0.12.0",
    "@vicons/material": "^0.13.0",
    "animejs": "^4.4.1",
    "axios": "^1.9.0",
    "echarts": "^5.6.0",
    "jsmind": "0.4.6",
    "ky": "^1.2.0",
    "naive-ui": "^2.41.0",
    "pinia": "^2.1.7",
    "pinia-plugin-persistedstate": "4.2.0",
    "vue": "^3.4.15",
    "vue-draggable-plus": "^0.6.0",
    "vue-hooks-plus": "^2.3.1",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@rushstack/eslint-patch": "^1.7.0",
    "@tsconfig/node18": "^18.2.2",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "@vitejs/plugin-vue": "^5.0.3",
    "@vitejs/plugin-vue-jsx": "^3.1.0",
    "@vue/eslint-config-prettier": "^9.0.0",
    "@vue/eslint-config-typescript": "^13.0.0",
    "@vue/tsconfig": "^0.5.1",
    "eslint": "^8.56.0",
    "eslint-plugin-vue": "^9.20.1",
    "express": "^4.18.2",
    "npm-run-all2": "^6.1.1",
    "prettier": "^3.2.4",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "vue-tsc": "^2.0.0"
  },
  "packageManager": "pnpm@10.11.1"
}
